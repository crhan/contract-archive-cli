# Document Intelligence Playground - 环境变量模板
# 复制此文件为 .env 后填入真实 key，.env 不会被 git 跟踪也不会被打印到日志

# ===== DashScope (阿里百炼) =====
# 同时用于 qwen-vl-ocr (OCR pipeline) 和 qwen3.7-max (Semantic Extraction)
DASHSCOPE_API_KEY=

# 端点：默认国内站；如用国际站改为 https://dashscope-intl.aliyuncs.com/api/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# OCR 模型
DASHSCOPE_OCR_MODEL=qwen-vl-ocr

# 语义抽取 LLM 模型
# 注意：qwen3.7-max 是用户在百炼控制台开通的特定别名，公网用户如果调用 404，
# 改成公开可用的 qwen-max / qwen-max-latest / qwen3-max（按账户能用什么填）
DASHSCOPE_LLM_MODEL=qwen3.7-max

# ===== 通用 =====
# 计算设备策略：auto 会依次尝试 MPS → CUDA → CPU；可硬编码 mps / cuda / cpu
COMPUTE_DEVICE=auto

# 输入/输出根目录（容器内或本机绝对路径均可）
INPUT_DIR=./input
OUTPUT_DIR=./output

# 日志级别
LOG_LEVEL=INFO
